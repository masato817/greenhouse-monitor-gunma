# ========================================
# 施設園芸環境モニタリングシステム .gitignore
# ========================================

# ----------------------------------------
# 環境変数・認証情報（最重要）
# ----------------------------------------
.env
.env.*
!.env.example

# Google Service Account Key
credentials/
*.pem
service-account*.json

# ----------------------------------------
# 依存関係
# ----------------------------------------
node_modules/

# ----------------------------------------
# ビルド出力
# ----------------------------------------
dist/

# ----------------------------------------
# ログファイル
# ----------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ----------------------------------------
# デバッグ用スクリーンショット
# （認証画面が含まれる可能性あり）
# ----------------------------------------
screenshots/

# ----------------------------------------
# デバッグ用ダンプHTML・スクリプト
# （ProfarmのHTMLダンプにハウスIDが含まれるためgit追跡外）
# ----------------------------------------
src/debug/

# ----------------------------------------
# IDE・エディタ
# ----------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# ----------------------------------------
# OS生成ファイル
# ----------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# ----------------------------------------
# 一時ファイル
# ----------------------------------------
*.tmp
*.temp
*.bak
temp/
tmp/

# ----------------------------------------
# テスト関連
# ----------------------------------------
coverage/
.nyc_output/

# ----------------------------------------
# その他
# ----------------------------------------
*.tgz
.cache/
