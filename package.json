{
  "name": "greenhouse-monitor",
  "version": "1.0.0",
  "description": "施設園芸環境モニタリングシステム - プロファインダー/プロファームからデータ取得してLINE通知",
  "main": "dist/app.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/app.js",
    "dev": "ts-node src/app.ts",
    "scrape": "ts-node src/app.ts --scrape",
    "scrape:profinder": "ts-node src/scrapers/profinder.ts",
    "scrape:profarm": "ts-node src/scrapers/profarm.ts",
    "check-alert": "ts-node src/services/alert-checker.ts",
    "test": "vitest",
    "lint": "eslint src/**/*.ts"
  },
  "dependencies": {
    "axios": "^1.5.0",
    "date-fns": "^2.30.0",
    "date-fns-tz": "^2.0.0",
    "dotenv": "^16.3.1",
    "googleapis": "^126.0.0",
    "handlebars": "^4.7.8",
    "node-cron": "^3.0.2",
    "puppeteer": "^21.0.0",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.2.0",
    "vitest": "^0.34.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}